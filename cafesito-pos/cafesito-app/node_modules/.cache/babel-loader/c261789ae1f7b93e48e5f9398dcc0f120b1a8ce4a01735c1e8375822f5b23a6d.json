=\"minus\" size={15}></Icon>\r\n              </Button>\r\n              <span data-testid=\"cart-item-quantity\">{item.quantity}</span>\r\n              <Button\r\n                variant=\"secondary\"\r\n                size=\"sm\"\r\n                onClick={() => updateQuantity(item._id, item.quantity + 1)}\r\n                data-testid=\"increase-qty-btn\"\r\n              >\r\n                <Icon name=\"plus\" size={15}></Icon>\r\n              </Button>\r\n            </div>\r\n\r\n            <div className=\"cart-item-total\" data-testid=\"cart-item-total\">\r\n              ${(item.price * item.quantity).toFixed(2)}\r\n            </div>\r\n\r\n            <Button\r\n              variant=\"ghost\"\r\n              className=\"danger\"\r\n              size=\"sm\"\r\n              onClick={() => removeFromCart(item._id)}\r\n              title=\"Eliminar artículo\"\r\n              data-testid=\"remove-item-btn\"\r\n            >\r\n              <Icon name=\"trash\" size={16} />\r\n            </Button>\r\n          </div>\r\n        ))}\r\n    </div>\r\n  );\r\n}\r\n"],"mappings":"AAAA,OAASA,OAAO,KAAQ,8BAA8B,CACtD,OAASC,MAAM,CAAEC,IAAI,KAAQ,aAAa,CAC1C,MAAO,gBAAgB,CAAC,OAAAC,IAAA,IAAAC,KAAA,CAAAC,GAAA,IAAAC,IAAA,yBAExB,cAAe,SAAS,CAAAC,QAAQA,CAAA,CAAG,CACjC,MAAAC,QAAA,CAAsDR,OAAO,CAAC,CAAC,CAAvDS,SAAS,CAAAD,QAAA,CAATC,SAAS,CAAEC,cAAc,CAAAF,QAAA,CAAdE,cAAc,CAAEC,cAAc,CAAAH,QAAA,CAAdG,cAAc,CAEjD,mBACEP,KAAA,QAAKQ,SAAS,CAAC,WAAW,CAAAC,QAAA,eACxBP,IAAA,QAAKM,SAAS,CAAC,kBAAkB,CAAAC,QAAA,cAC/BT,KAAA,OAAI,cAAY,YAAY,CAAAS,QAAA,EACzBJ,SAAS,CAACK,MAAM,CAAC,GAAC,CAACL,SAAS,CAACK,MAAM,GAAK,CAAC,CAAG,UAAU,CAAG,WAAW,EACnE,CAAC,CACF,CAAC,CAELL,SAAS,EACRA,SAAS,CAACM,GAAG,CAAEC,IAAI,eACjBZ,KAAA,QAAKQ,SAAS,CAAC,WAAW,CAAgB,cAAY,WAAW,CAAAC,QAAA,eAC/DP,IAAA,QAAKM,SAAS,CAAC,iBAAiB,CAAAC,QAAA,cAC9BP,IAAA,QAAKW,GAAG,CAAED,IAAI,CAACE,SAAS,CAAC,CAAC,CAAE,CAACC,GAAG,CAAEH,IAAI,CAACI,IAAK,CAACC,OAAO,CAAC,MAAM,CAAE,CAAC,CAC3D,CAAC,cAENjB,KAAA,QAAKQ,SAAS,CAAC,gBAAgB,CAAAC,QAAA,eAC7B